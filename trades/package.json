{
  "name": "trades",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently \"npm run dev\" \"npm run server:dev\"",
    "server:dev": "npm --prefix ../server run dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "check": "npm run lint && npm run build",
    "preview": "vite preview",
    "test": "vitest run src/logic/*.test.ts",
    "test:fuzz": "vitest run src/logic/fuzzer.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "evidence:videos": "node scripts/record-evidence-videos.mjs",
    "evidence:gameplay-videos": "node scripts/record-gameplay-videos.mjs",
    "evidence:random-viable-video": "node scripts/record-random-viable-video.mjs"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ts-pattern": "^5.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.3.1",
    "vitest": "^3.2.4"
  }
}
